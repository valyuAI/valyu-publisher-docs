{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Valyu Publisher",
  "colors": {
    "primary": "#10B981",
    "light": "#34D399",
    "dark": "#059669"
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "heading": {
      "family": "DM Sans",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "appearance": {
    "default": "dark"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark-dimmed"
      }
    }
  },
  "background": {
    "decoration": "gradient"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart", "authentication"]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/usage-analytics",
              "guides/earnings-tracking",
              "guides/data-export"
            ]
          },
          {
            "group": "Concepts",
            "pages": ["guides/how-it-works", "guides/api-keys"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/overview"]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/usage",
              "api-reference/endpoint/earnings",
              "api-reference/endpoint/activity",
              "api-reference/endpoint/export"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Publisher Dashboard",
          "href": "https://publisher.valyu.ai",
          "icon": "chart-line"
        },
        {
          "anchor": "Valyu Docs",
          "href": "https://docs.valyu.ai",
          "icon": "book"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/valyuAI",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "title": "Valyu Publisher API - Analytics for Data Publishers",
      "description": "API documentation for Valyu publishers. Access your usage analytics, earnings data, and export capabilities programmatically.",
      "og:title": "Valyu Publisher API - Analytics for Data Publishers",
      "og:description": "Programmatic access to your publisher analytics - usage metrics, earnings tracking, and data export via REST API.",
      "og:type": "website",
      "twitter:card": "summary_large_image",
      "twitter:site": "@ValyuOfficial"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Contact",
        "href": "mailto:contact@valyu.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Publisher Dashboard",
      "href": "https://publisher.valyu.ai"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/ValyuOfficial",
      "github": "https://github.com/valyuAI",
      "linkedin": "https://linkedin.com/company/valyu-ai",
      "discord": "https://discord.gg/umtmSsppRY"
    }
  },
  "api": {
    "openapi": "/api-reference/openapi.yaml",
    "server": "https://api.publisher.valyu.ai/v1",
    "auth": {
      "method": "key",
      "name": "x-api-key"
    },
    "playground": {
      "mode": "simple"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  }
}
